---
import Base from '../layouts/Base.astro';
---
<Base title="Not found — Pulling Threads" description="That page doesn't exist.">
  <section class="store" style="min-height:70vh; display:flex; align-items:center;">
    <div class="wrap" style="width:100%">
      <span class="tag tag-line">404</span>
      <h2>Pulled the wrong thread</h2>
      <p>That page doesn't exist. It might have, once. It doesn't now.</p>
      <a class="btn btn-primary" href="/" style="margin-top:26px">Back to the start</a>
    </div>
  </section>
</Base>
