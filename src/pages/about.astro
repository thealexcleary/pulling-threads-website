---
import Base from '../layouts/Base.astro';
import { Content as About } from '../content/about.md';
---
<Base
  title="About — Pulling Threads"
  description="Two brothers from Mount Isa. Who Alex and Troy Cleary are, and why the Pulling Threads podcast exists."
>
  <section class="about-sec" style="padding-top:140px">
    <div class="wrap about">
      <div class="duo">
        <figure><img src="/images/alex.jpg" alt="Alex Cleary" width="640" height="853" /><figcaption>Alex</figcaption></figure>
        <figure><img src="/images/troy.jpg" alt="Troy Cleary" width="640" height="800" /><figcaption>Troy</figcaption></figure>
      </div>
      <div class="about-copy prose">
        <About />
      </div>
    </div>
  </section>
</Base>
